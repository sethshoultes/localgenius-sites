# ============================================================
# LocalGenius Sites — Environment Variables
# ============================================================
# Copy this file to .env (for local dev) or use `wrangler secret put`
# for production secrets. Non-secret vars are set in wrangler.toml [vars].
# ============================================================

# ----------------------------------------------------------
# Cloudflare API credentials (SECRETS — use wrangler secret put)
# Used by the provisioning service to create D1 databases,
# R2 buckets, Workers, and DNS records via the Cloudflare API.
# ----------------------------------------------------------

# Cloudflare API token with permissions: D1, R2, Workers, DNS
CLOUDFLARE_API_TOKEN=

# Your Cloudflare account ID (found in the dashboard URL or Overview page)
CLOUDFLARE_ACCOUNT_ID=

# Zone ID for the localgenius.site domain (found in the domain's Overview page)
CLOUDFLARE_ZONE_ID=

# ----------------------------------------------------------
# MCP Bridge (SECRETS — use wrangler secret put)
# Used to authenticate requests between the LocalGenius AI
# assistant and each business site's Emdash MCP server.
# ----------------------------------------------------------

# Shared secret for authenticating MCP tool calls to site endpoints
MCP_SHARED_SECRET=

# ----------------------------------------------------------
# Non-secret vars (already defined in wrangler.toml [vars])
# Listed here for reference — override locally if needed.
# ----------------------------------------------------------

# Runtime environment: "production" | "staging"
ENVIRONMENT=production

# Base domain for provisioned business sites (e.g. slug.localgenius.site)
LOCALGENIUS_DOMAIN=localgenius.site

# Worker template name used when deploying new Emdash sites
EMDASH_WORKER_TEMPLATE=localgenius-site-template
