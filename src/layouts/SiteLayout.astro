---
import '../styles/global.css';
import { getTheme, generateCSSVariables } from '../design/design-tokens';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  businessName: string;
  theme?: 'craft' | 'professional';
  address?: string;
  phone?: string;
  hours?: string;
}

const {
  title,
  description,
  businessName,
  theme = 'craft',
  address = '',
  phone = '',
  hours = '',
} = Astro.props;

const activeTheme = getTheme(theme);
const cssVars = generateCSSVariables(activeTheme);
const canonicalUrl = Astro.url.href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={businessName} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Google Fonts: Lora (display) + Source Sans 3 (body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Source+Sans+3:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Theme CSS custom properties -->
    <Fragment set:html={`<style>:root{${cssVars}}</style>`} />
  </head>
  <body class={`theme-${theme}`}>
    <Nav businessName={businessName} />

    <main>
      <slot />
    </main>

    <Footer
      businessName={businessName}
      address={address}
      phone={phone}
      hours={hours}
    />
  </body>
</html>

<style is:global>
  /* Theme font overrides — Craft uses Lora for display, Source Sans 3 for body */
  .theme-craft {
    --font-display: 'Lora', 'Georgia', serif;
    --font-body: 'Source Sans 3', 'Inter', system-ui, sans-serif;
  }

  /* Professional uses Source Sans 3 for everything */
  .theme-professional {
    --font-display: 'Source Sans 3', 'Inter', system-ui, sans-serif;
    --font-body: 'Source Sans 3', 'Inter', system-ui, sans-serif;
  }
</style>
