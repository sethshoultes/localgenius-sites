---
interface Props {
  businessName: string;
}

const { businessName } = Astro.props;
---

<nav class="site-nav" aria-label="Main navigation">
  <div class="nav-inner container">
    <a href="/" class="nav-brand">{businessName}</a>

    <!-- CSS-only hamburger toggle -->
    <input
      type="checkbox"
      id="nav-toggle"
      class="nav-toggle-input sr-only"
      aria-label="Toggle navigation menu"
    />
    <label for="nav-toggle" class="nav-hamburger" aria-hidden="true">
      <span class="hamburger-bar"></span>
      <span class="hamburger-bar"></span>
      <span class="hamburger-bar"></span>
    </label>

    <ul class="nav-links" role="list">
      <li><a href="#menu">Menu</a></li>
      <li><a href="#hours">Hours</a></li>
      <li><a href="#contact">Contact</a></li>
    </ul>
  </div>
</nav>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--color-bg-elevated, #ffffff);
    box-shadow: 0 1px 3px rgb(0 0 0 / 0.06), 0 1px 2px rgb(0 0 0 / 0.04);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 4rem;
    gap: 1.5rem;
  }

  .nav-brand {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--color-text-primary);
    text-decoration: none;
    white-space: nowrap;
    letter-spacing: -0.01em;
    line-height: 1;
  }

  .nav-brand:hover {
    color: var(--color-brand);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-links a {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: color 150ms ease;
    padding: 0.25rem 0;
    position: relative;
  }

  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 2px;
    background-color: var(--color-brand);
    transition: width 200ms ease;
  }

  .nav-links a:hover {
    color: var(--color-text-primary);
  }

  .nav-links a:hover::after {
    width: 100%;
  }

  /* Hamburger — hidden on desktop */
  .nav-hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 2rem;
    height: 2rem;
    cursor: pointer;
  }

  .hamburger-bar {
    display: block;
    width: 100%;
    height: 2px;
    background-color: var(--color-text-primary);
    border-radius: 1px;
    transition: transform 250ms ease, opacity 250ms ease;
  }

  /* Toggle input is visually hidden via .sr-only */
  .nav-toggle-input {
    /* sr-only handles this */
  }

  /* ---- Mobile ---- */
  @media (max-width: 767px) {
    .nav-hamburger {
      display: flex;
    }

    .nav-links {
      position: absolute;
      top: 4rem;
      left: 0;
      right: 0;
      flex-direction: column;
      gap: 0;
      background-color: var(--color-bg-elevated, #ffffff);
      box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.07);
      max-height: 0;
      overflow: hidden;
      transition: max-height 300ms ease;
    }

    .nav-links li {
      width: 100%;
    }

    .nav-links a {
      display: block;
      padding: 0.875rem 1.5rem;
      font-size: 1rem;
      border-bottom: 1px solid var(--color-border, #e7e5e4);
    }

    .nav-links a::after {
      display: none;
    }

    /* Open state */
    .nav-toggle-input:checked ~ .nav-links {
      max-height: 20rem;
    }

    /* Hamburger animation */
    .nav-toggle-input:checked ~ .nav-hamburger .hamburger-bar:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }

    .nav-toggle-input:checked ~ .nav-hamburger .hamburger-bar:nth-child(2) {
      opacity: 0;
    }

    .nav-toggle-input:checked ~ .nav-hamburger .hamburger-bar:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }
  }
</style>
