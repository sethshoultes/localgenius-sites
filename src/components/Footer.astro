---
interface Props {
  businessName: string;
  address?: string;
  phone?: string;
  hours?: string;
}

const { businessName, address = '', phone = '', hours = '' } = Astro.props;
---

<footer class="site-footer">
  <div class="footer-inner container">
    <div class="footer-main">
      <div class="footer-business">
        <p class="footer-name">{businessName}</p>
        {address && <p class="footer-address">{address}</p>}
        {phone && (
          <p class="footer-phone">
            <a href={`tel:${phone.replace(/[^+\d]/g, '')}`}>{phone}</a>
          </p>
        )}
      </div>

      {hours && (
        <div class="footer-hours">
          <p class="footer-hours-label">Hours</p>
          <p class="footer-hours-text">{hours}</p>
        </div>
      )}
    </div>

    <div class="footer-bottom">
      <p class="footer-credit">Made with LocalGenius</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-bg-sunken, #f5f5f4);
    border-top: 1px solid var(--color-border, #e7e5e4);
    padding-top: 3rem;
    padding-bottom: 1.5rem;
    margin-top: 4rem;
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .footer-main {
    display: flex;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .footer-business {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .footer-name {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: 0.25rem;
  }

  .footer-address,
  .footer-hours-text {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
    margin-bottom: 0;
  }

  .footer-phone a {
    font-size: 0.9375rem;
    color: var(--color-brand);
    text-decoration: none;
    font-weight: 500;
  }

  .footer-phone a:hover {
    color: var(--color-brand-hover);
    text-decoration: underline;
  }

  .footer-hours {
    text-align: right;
  }

  .footer-hours-label {
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-tertiary, #a8a29e);
    margin-bottom: 0.375rem;
  }

  .footer-bottom {
    border-top: 1px solid var(--color-border, #e7e5e4);
    padding-top: 1.25rem;
    text-align: center;
  }

  .footer-credit {
    font-size: 0.8125rem;
    color: #5C6B52;
    letter-spacing: 0.02em;
    margin-bottom: 0;
  }

  @media (max-width: 767px) {
    .footer-main {
      flex-direction: column;
    }

    .footer-hours {
      text-align: left;
    }
  }
</style>
