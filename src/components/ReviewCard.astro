---
import StarRating from './StarRating.astro';

interface Props {
  reviewer: string;
  rating: number;
  text: string;
  date: string;
  platform: string;
}

const { reviewer, rating, text, date, platform } = Astro.props;

// Truncate long reviews
const maxLength = 280;
const isLong = text.length > maxLength;
const displayText = isLong ? text.slice(0, maxLength).trimEnd() + '...' : text;

// Format the date for display
const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

// Platform badge labels
const platformLabel = platform.charAt(0).toUpperCase() + platform.slice(1).toLowerCase();
---

<article class="review-card">
  <div class="review-header">
    <StarRating rating={rating} />
    <span class={`review-platform platform-${platform.toLowerCase()}`}>
      {platformLabel}
    </span>
  </div>

  <p class="review-text">{displayText}</p>

  <div class="review-footer">
    <span class="review-author">{reviewer}</span>
    <span class="review-date">{formattedDate}</span>
  </div>
</article>

<style>
  .review-card {
    background-color: var(--color-surface, #ffffff);
    border: 1px solid var(--color-border, #e7e5e4);
    border-radius: 0.75rem;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    transition: box-shadow 200ms ease;
  }

  .review-card:hover {
    box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.07), 0 2px 4px -2px rgb(0 0 0 / 0.05);
  }

  .review-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .review-platform {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    padding: 0.2rem 0.625rem;
    border-radius: 9999px;
    line-height: 1.4;
  }

  .platform-google {
    background-color: #e8f0fe;
    color: #1a73e8;
  }

  .platform-yelp {
    background-color: #fce4e4;
    color: #d32323;
  }

  /* Fallback for other platforms */
  .review-platform:not(.platform-google):not(.platform-yelp) {
    background-color: var(--color-surface-muted, #f5f5f4);
    color: var(--color-text-secondary, #78716c);
  }

  .review-text {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-text-primary);
    margin-bottom: 0;
  }

  .review-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding-top: 0.5rem;
    border-top: 1px solid var(--color-border, #e7e5e4);
  }

  .review-author {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-primary);
  }

  .review-date {
    font-size: 0.8125rem;
    color: var(--color-text-tertiary, #a8a29e);
  }
</style>
